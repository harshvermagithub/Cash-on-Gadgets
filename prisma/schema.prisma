generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  role             String    @default("USER")
  phone            String?   @unique
  resetToken       String?
  resetTokenExpiry DateTime?
  cityId           String?
  pincodes         String[]  @default([])
  managedCities    City[]    @relation("ZonalManager")
  
  // Hierarchical Management
  managerId        String?
  manager          User?     @relation("UserManagement", fields: [managerId], references: [id])
  managedUsers     User[]    @relation("UserManagement")

  orders           Order[]
  riders           Rider[]
  city             City?     @relation("UserCity", fields: [cityId], references: [id])
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive     Boolean  @default(true)
  pincodes     String[] @default([])
  displayOrder Int      @default(0)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  managerId String?
  manager   User?    @relation("ZonalManager", fields: [managerId], references: [id])
  users     User[]   @relation("UserCity")
}

model Rider {
  id        String   @id @default(cuid())
  name      String
  phone     String
  status    String   @default("available")
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partnerId String?
  orders    Order[]
  partner   User?    @relation(fields: [partnerId], references: [id])
}

model Order {
  id                 String   @id @default(cuid())
  userId             String
  riderId            String?
  device             String
  price              Int
  status             String   @default("Pending Pickup")
  address            String
  locationLat        Float?
  locationLng        Float?
  answers            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  orderNumber        Int      @unique @default(autoincrement())
  pincode            String?
  offeredPrice       Int?
  riderAnswers       String?
  verificationImages String[] @default([])
  rider              Rider?   @relation(fields: [riderId], references: [id])
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Brand {
  id         String   @id
  name       String
  logo       String
  categories String[] @default([])
  priority   Int      @default(100)
  models     Model[]
}

model Model {
  id       String    @id @default(cuid())
  brandId  String
  name     String
  img      String
  category String    @default("smartphone")
  priority Int       @default(100)
  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants Variant[]
}

model Variant {
  id        String @id @default(cuid())
  modelId   String
  name      String
  basePrice Int
  model     Model  @relation(fields: [modelId], references: [id], onDelete: Cascade)
}

model EvaluationRule {
  id               String   @id @default(cuid())
  category         String
  questionKey      String
  answerKey        String
  label            String
  deductionAmount  Int      @default(0)
  deductionPercent Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([category, questionKey, answerKey])
}

model EmailMessage {
  id         String   @id @default(cuid())
  messageId  String?  @unique
  from       String
  to         String
  subject    String?
  bodySnippet String?
  bodyText   String?
  bodyHtml   String?
  receivedAt DateTime @default(now())
  isOutbound Boolean  @default(false)
  status     String   @default("delivered")
  threadId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailAccount {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DeviceDisplayPrice {
  id            String   @id @default(cuid())
  categoryKey   String   @unique // e.g., 'phones', 'tablets', 'laptops', 'watches', 'cameras'
  categoryName  String   // e.g., 'Smartphones'
  displayPrice  String   // e.g., '₹129k+'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
